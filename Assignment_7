# Step 2: Import Library
from transformers import pipeline

print("Assignment 7: T5 Transformer Model")

# Step 3: Input Text
text = "translate English to Hindi: I love NLP"
print("\nInput:", text)

# Step 4: Load T5 Model and Generate Output
try:
    # Load pre-trained T5 model
    t5 = pipeline("text2text-generation", model="t5-small")
    
    print("\nT5 model loaded successfully.")
    
    # Generate output
    result = t5(text, max_length=50)
    output = result[0]['generated_text']
    
    print("\nOutput (Generated by T5):", output)

except Exception as e:
    print("\nModel could not be loaded due to system limitations.")
    print("Error:", e)

    # Demonstration Output (Fallback)
    print("\nExpected Output:", "मुझे NLP पसंद है")

# Step 5: Explanation
print("\nExplanation:")
print("T5 (Text-To-Text Transfer Transformer) converts input text into output text.")
print("It follows a transformer-based encoder-decoder architecture.")
print("Example task performed here: Translation (English → Hindi)")
